{
  "name": "co-change",
  "version": "0.1.0",
  "description": "Analyze git commit history to find files that frequently change together",
  "type": "module",
  "main": "dist/analyzer.js",
  "exports": {
    ".": {
      "import": "./dist/analyzer.js",
      "types": "./dist/analyzer.d.ts"
    },
    "./results": {
      "import": "./dist/results.js",
      "types": "./dist/results.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "bin": {
    "co-change": "dist/bin/co-change.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": ["git", "co-change", "coupling", "analysis", "refactoring", "cli"],
  "scripts": {
    "build": "tsc",
    "analyze": "tsx src/bin/co-change.ts analyze",
    "display": "tsx src/bin/co-change.ts display",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
